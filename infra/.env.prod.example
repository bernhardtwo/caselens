# Production compose environment.
# Copy to infra/.env.prod (gitignored) and fill in CO_API_KEY before:
#   docker compose -f infra/docker-compose.prod.yml up --build

# Required. Cohere key used by the api and by the bootstrap corpus ingest.
# Loaded into the containers at runtime; never baked into the images.
CO_API_KEY=

# The values below already have working defaults in the compose file; override only
# if you change the topology. They are listed here as documentation.
#
# DATABASE_URL: api/bootstrap -> postgres (compose sets this for the internal network)
#   DATABASE_URL=postgresql://caselens:caselens@postgres:5432/caselens
#
# API_INTERNAL_URL: the web proxy target (compose sets this to the api service)
#   API_INTERNAL_URL=http://api:8000
#
# WEB_PORT: host port for the web console (shell/.env substitution, defaults to 3000)
#   WEB_PORT=3000
